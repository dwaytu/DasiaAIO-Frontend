# Required API endpoint (fully-qualified URL)
VITE_API_BASE_URL=https://api.example.com

# App version displayed in update prompts
VITE_APP_VERSION=1.0.0

# Optional release metadata endpoints
VITE_LATEST_RELEASE_API_URL=https://api.github.com/repos/Cloudyrowdyyy/Capstone-Main/releases/latest
VITE_RELEASE_DOWNLOAD_URL=https://github.com/Cloudyrowdyyy/Capstone-Main/releases/latest

# Suggested mode-specific files (create as needed):
# .env.web       -> production web endpoint
# .env.desktop   -> production desktop endpoint
# .env.mobile    -> production mobile endpoint
# .env.staging   -> staging endpoint (HTTPS recommended)
