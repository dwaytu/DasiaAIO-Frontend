# Required API endpoint (fully-qualified URL)
VITE_API_BASE_URL=https://api.example.com

# App version displayed in update prompts
VITE_APP_VERSION=1.0.0
VITE_WHATS_NEW=Platform stability and security hardening improvements.

# Optional release metadata endpoints
VITE_LATEST_RELEASE_API_URL=https://api.github.com/repos/dwaytu/Capstone-Main/releases/latest
VITE_RELEASE_DOWNLOAD_URL=https://github.com/dwaytu/Capstone-Main/releases/latest

# Enable real-time WebSocket tracking (guard location → superadmin map)
VITE_ENABLE_TRACKING_WS=true

# Tracking accuracy mode: 'strict' (20m, 3min recency) or 'balanced' (35m, 8min recency)
# Use 'balanced' for real-world mobile GPS in urban/indoor environments
VITE_TRACKING_ACCURACY_MODE=balanced

# Suggested mode-specific files (create as needed):
# .env.web       -> production web endpoint
# .env.desktop   -> production desktop endpoint
# .env.mobile    -> production mobile endpoint
# .env.staging   -> staging endpoint (HTTPS recommended)
